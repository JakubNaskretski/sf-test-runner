{
  "name": "sf-test-runner",
  "displayName": "Salesforce Test Runner",
  "description": "Run Apex tests with inline coverage in the gutter, browse results in a sidebar tree, and see every sf CLI command we execute in a collapsible panel. Reuses your existing sf CLI auth.",
  "version": "0.4.2",
  "publisher": "Skrety",
  "icon": "icons/plugin-icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "salesforce",
    "apex",
    "test",
    "coverage",
    "sf",
    "sfdx"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:apex",
    "onView:sfTestRunner.results",
    "onView:sfTestRunner.commands",
    "workspaceContains:**/*.cls"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sfTestRunner.runCurrentClass",
        "title": "SF Tests: Run Tests in Current Class",
        "icon": "$(play)"
      },
      {
        "command": "sfTestRunner.runLast",
        "title": "SF Tests: Re-run Last Class",
        "icon": "$(run-all)"
      },
      {
        "command": "sfTestRunner.runTestMethod",
        "title": "SF Tests: Run Test Method"
      },
      {
        "command": "sfTestRunner.rerunFailed",
        "title": "SF Tests: Re-run Failed Tests",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "sfTestRunner.loadRecentRuns",
        "title": "SF Tests: Load Recent Test Runs",
        "icon": "$(history)"
      },
      {
        "command": "sfTestRunner.refreshCoverage",
        "title": "SF Tests: Refresh Coverage from Org",
        "icon": "$(refresh)"
      },
      {
        "command": "sfTestRunner.clearCoverage",
        "title": "SF Tests: Clear Coverage Decorations",
        "icon": "$(clear-all)"
      },
      {
        "command": "sfTestRunner.selectOrg",
        "title": "SF Tests: Select Target Org",
        "icon": "$(plug)"
      },
      {
        "command": "sfTestRunner.openTestResult",
        "title": "SF Tests: Open Test Result"
      },
      {
        "command": "sfTestRunner.clearCommandHistory",
        "title": "SF Tests: Clear Command History",
        "icon": "$(clear-all)"
      },
      {
        "command": "sfTestRunner.copyCommand",
        "title": "SF Tests: Copy Command",
        "icon": "$(copy)"
      },
      {
        "command": "sfTestRunner.showOutput",
        "title": "SF Tests: Show Output Channel",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "sfTestRunner.runTestMethod",
          "when": "false"
        },
        {
          "command": "sfTestRunner.openTestResult",
          "when": "false"
        },
        {
          "command": "sfTestRunner.copyCommand",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "sfTestRunner.runLast",
          "when": "view == sfTestRunner.results",
          "group": "navigation@1"
        },
        {
          "command": "sfTestRunner.rerunFailed",
          "when": "view == sfTestRunner.results",
          "group": "navigation@2"
        },
        {
          "command": "sfTestRunner.loadRecentRuns",
          "when": "view == sfTestRunner.results",
          "group": "navigation@3"
        },
        {
          "command": "sfTestRunner.refreshCoverage",
          "when": "view == sfTestRunner.results",
          "group": "navigation@4"
        },
        {
          "command": "sfTestRunner.selectOrg",
          "when": "view == sfTestRunner.results",
          "group": "navigation@5"
        },
        {
          "command": "sfTestRunner.clearCommandHistory",
          "when": "view == sfTestRunner.commands",
          "group": "navigation@1"
        },
        {
          "command": "sfTestRunner.showOutput",
          "when": "view == sfTestRunner.commands",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "sfTestRunner.copyCommand",
          "when": "view == sfTestRunner.commands && viewItem == sfCommand",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "sfTestRunner.runCurrentClass",
          "when": "resourceExtname == .cls",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sfTestRunner",
          "title": "SF Tests",
          "icon": "icons/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "sfTestRunner": [
        {
          "id": "sfTestRunner.results",
          "name": "Test Results",
          "icon": "$(beaker)",
          "contextualTitle": "Salesforce Test Runner"
        },
        {
          "id": "sfTestRunner.commands",
          "name": "Recent sf Commands",
          "icon": "$(terminal)",
          "contextualTitle": "Salesforce Test Runner"
        }
      ]
    },
    "configuration": {
      "title": "Salesforce Test Runner",
      "properties": {
        "sfTestRunner.testTimeoutMs": {
          "type": "number",
          "default": 600000,
          "minimum": 60000,
          "description": "Hard timeout (ms) for `sf apex run test`. Also drives the --wait minutes flag."
        },
        "sfTestRunner.showCoverageOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "When an Apex class is opened, auto-load its most recent coverage from the org."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npx -y @vscode/vsce@latest package --no-dependencies --allow-missing-repository",
    "publish": "npx -y @vscode/vsce@latest publish --no-dependencies --allow-missing-repository",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc -p ./tsconfig.test.json",
    "test": "node --test \"out-test/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
